# Auto-Approval Configuration
# 
# This file defines policies for autonomous production deployment approval.
# Place this in .github/auto-approval-config.env
#
# IMPORTANT: Also configure GitHub repository secrets for options that reference them:
# - SLACK_WEBHOOK_URL (optional): Slack webhook for notifications
#

# ═══════════════════════════════════════════════════════════════════
# FEATURE TOGGLES
# ═══════════════════════════════════════════════════════════════════

# Enable or disable the entire auto-approval engine
# Set to 'true' to enable autonomous approvals
# Set to 'false' to require manual approval (default)
AUTO_APPROVAL_ENABLED=true

# ═══════════════════════════════════════════════════════════════════
# CONFIDENCE THRESHOLDS
# ═══════════════════════════════════════════════════════════════════

# Minimum confidence score (0.0 - 1.0) required for auto-approval
# Default: 0.90 (very conservative)
# Recommendation: Keep >= 0.85 for safety
MIN_CONFIDENCE_FOR_AUTO=0.90

# ═══════════════════════════════════════════════════════════════════
# CHANGE-TYPE POLICIES
# ═══════════════════════════════════════════════════════════════════

# Auto-approve patch releases (semantic version patches, bug fixes)
# Examples: fix(cluster), patch, bump version
AUTO_APPROVE_ON_PATCH=true

# Auto-approve add-on updates (Helm charts, managed add-ons)
# Examples: addon(*, feat(addon, update helm chart
AUTO_APPROVE_ON_ADDON_UPDATE=true

# Auto-approve security fixes (tfsec, CVE patches, security hardening)
# Examples: security fix, CVE-2024-*, tfsec remediation
# ⚠️  WARNING: High priority, but still requires clean checks
AUTO_APPROVE_ON_SECURITY_FIX=true

# ═══════════════════════════════════════════════════════════════════
# BLOCKING POLICIES
# ═══════════════════════════════════════════════════════════════════

# Require manual approval for infrastructure changes (high risk)
# Examples: terraform module changes, network changes, cluster config
# When true: infrastructure changes ALWAYS require manual approval
REQUIRE_MANUAL_ON_INFRASTRUCTURE_CHANGE=true

# Require manual approval for cost increase (budget safety)
# When true: ANY cost increase > $500/month requires manual approval
# Even if confidence is high, deployment is blocked for cost changes
REQUIRE_MANUAL_ON_COST_INCREASE=true

# ═══════════════════════════════════════════════════════════════════
# NOTIFICATIONS
# ═══════════════════════════════════════════════════════════════════

# Enable Slack notifications for deployment decisions
NOTIFY_SLACK=false

# Slack webhook URL (set as GitHub secret: SLACK_WEBHOOK_URL)
# In pipeline, reference as: ${{ secrets.SLACK_WEBHOOK_URL }}
SLACK_WEBHOOK=$SLACK_WEBHOOK_URL

# ═══════════════════════════════════════════════════════════════════
# SECURITY THRESHOLDS
# ═══════════════════════════════════════════════════════════════════

# Maximum acceptable CRITICAL security findings
# Default: 0 (zero tolerance)
MAX_CRITICAL_ISSUES=0

# Maximum acceptable HIGH severity findings
# Default: 3 (limited tolerance)
MAX_HIGH_ISSUES=3

# Maximum acceptable policy violations (checkov)
# Default: 10 (minor violations allowed)
MAX_POLICY_VIOLATIONS=10

# ═══════════════════════════════════════════════════════════════════
# COST THRESHOLDS
# ═══════════════════════════════════════════════════════════════════

# Cost increase threshold (in USD/month) before manual approval required
# Default: $500
COST_THRESHOLD_USD=1000

# Cost increase threshold for test/staging/prod (if different)
COST_THRESHOLD_TEST_USD=100
COST_THRESHOLD_STAGING_USD=500
COST_THRESHOLD_PROD_USD=1000

# ═══════════════════════════════════════════════════════════════════
# CRITICAL INFRASTRUCTURE MODULES (changes always require manual prod approval)
# ═══════════════════════════════════════════════════════════════════

# Space-separated list of terraform/modules/* subdirectory names that are
# considered critical. Changes to these always require manual approval.
# App-level modules (ecr, app, addons) are intentionally excluded.
CRITICAL_TF_MODULES="vpc eks iam github_oidc"

# ═══════════════════════════════════════════════════════════════════
# DRIFT & INFRASTRUCTURE SAFETY
# ═══════════════════════════════════════════════════════════════════

# Maximum number of unexpected infrastructure changes (drift) before manual review
# Default: 0 (no drift tolerance)
MAX_DRIFT_RESOURCES=0

# Require manual approval if terraform plan contains >N changes
# This is a safety measure to catch bulk changes
REQUIRE_MANUAL_IF_CHANGES_EXCEED=50

# ═══════════════════════════════════════════════════════════════════
# DEPLOYMENT WINDOWS (FUTURE)
# ═══════════════════════════════════════════════════════════════════

# Auto-approval only allowed during business hours (HH:MM in UTC)
# Set to empty string to allow 24/7 auto-approval
DEPLOYMENT_WINDOW_START=09:00
DEPLOYMENT_WINDOW_END=17:00
DEPLOYMENT_WINDOW_ENABLED=false

# Restrict auto-approval to certain days (FUTURE)
# Example: "Mon,Tue,Wed,Thu,Fri" for weekdays only
DEPLOYMENT_ALLOWED_DAYS=

# ═══════════════════════════════════════════════════════════════════
# AUDIT & LOGGING
# ═══════════════════════════════════════════════════════════════════

# Enable detailed decision logging
DECISION_LOGGING_ENABLED=true

# Log file location (relative to repo root)
DECISION_LOG_FILE=artifacts/auto-approval-engine.log

# ═══════════════════════════════════════════════════════════════════
# EXPERIMENTAL / FUTURE
# ═══════════════════════════════════════════════════════════════════

# Allow rollback of deployments without manual approval (FUTURE)
AUTO_ROLLBACK_ON_HEALTH_CHECK_FAILURE=false

# Require human review in code after auto-approval succeeded (audit trail)
CREATE_AUDIT_PR_AFTER_AUTO_APPROVAL=false
